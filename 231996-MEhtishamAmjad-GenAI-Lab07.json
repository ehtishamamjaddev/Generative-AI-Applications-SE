    {
      "parameters": {
        "jsCode": "// Track round using a static counter approach\nconst items = $input.all();\nconst inputData = items[0].json;\n\n// critique comes from Critic via Check Approved false branch\nconst critique = inputData.choices?.[0]?.message?.content || inputData.critique || '';\nconst current_code = $('Generator').first().json.choices[0].message.content;\nconst task = $('Initialize Counter').first().json.task;\n\n// Count how many times Round Counter has been called\nconst executionCount = $execution.customData?.get?.('round') ?? 0;\nconst newRound = Number(executionCount) + 1;\n\nreturn [{\n  json: {\n    task: task,\n    round: newRound,\n    critique: critique,\n    current_code: current_code\n  }\n}];"
      },

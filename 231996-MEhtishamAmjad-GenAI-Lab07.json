    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\nconst code = inputData.generated_code || inputData.choices?.[0]?.message?.content || '';\n\nreturn [{\n  json: {\n    model: \"llama-3.1-8b-instant\",\n    temperature: 0.3,\n    max_tokens: 1024,\n    messages: [\n      {\n        role: \"system\",\n        content: \"You are a senior code reviewer for financial fraud detection systems. Evaluate the Python code against:\\n1. Correctness of fraud logic\\n2. Explainability of decisions\\n3. Absence of demographic bias\\n4. Edge cases for unusual transactions\\n5. Regulatory compliance language\\n\\nFor each problem write:\\nISSUE [criterion]: specific problem\\n\\nIf ALL five criteria are met, respond with exactly one word: APPROVED\\n\\nNever say APPROVED if any criterion has an issue.\"\n      },\n      {\n        role: \"user\",\n        content: \"Review this Python code:\\n\\n\" + code\n      }\n    ]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        -112
      ],
      "id": "449ff9ce-00e9-4a3e-88f9-e5498cfcbd01",
      "name": "Build Critic Payload"
    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\n\nconst task = inputData.task || $('Initialize Counter').first().json.task || '';\nconst critique = inputData.critique || null;\nconst current_code = inputData.current_code || null;\n\nconst userMessage = (critique && current_code)\n  ? `Revise this Python code.\\n\\nOriginal:\\n${current_code}\\n\\nCritique:\\n${critique}`\n  : task;\n\nreturn [{\n  json: {\n    model: \"llama-3.1-8b-instant\",\n    temperature: 0.3,\n    max_tokens: 1024,\n    messages: [\n      {\n        role: \"system\",\n        content: \"You are an expert Python developer. Write a clean working Python function with a docstring. Handle edge cases. Return ONLY Python code no explanation no markdown.\"\n      },\n      {\n        role: \"user\",\n        content: userMessage\n      }\n    ]\n  }\n}];"
      },

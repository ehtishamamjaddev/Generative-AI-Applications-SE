    {
      "parameters": {
        "jsCode": "// Get query keywords from the first Code node\nconst queryKeywords = $('Code in JavaScript').item.json.queryKeywords;  // array of strings\nconst question      = $('Code in JavaScript').item.json.question;\nconst studentName   = $('Code in JavaScript').item.json.studentName;\n\n// Get all KB rows from Google Sheets\nconst allEntries = $input.all();\n\n// Score each entry by counting keyword matches\nconst scored = allEntries.map(item => {\n  const entry    = item.json;\n  const kbText   = `${entry.Keywords} ${entry.Content} ${entry.Topic}`.toLowerCase();\n\n  // Count how many query keywords appear in this KB entry\n  const matchCount = queryKeywords.filter(kw => kbText.includes(kw)).length;\n\n  // Bonus: exact topic word match scores higher\n  const topicBonus = queryKeywords.some(kw =>\n    (entry.Topic || '').toLowerCase().includes(kw)) ? 1 : 0;\n\n  return {\n    ...entry,\n    _score: matchCount + topicBonus,\n  };\n}).filter(e => e._score > 0)            // keep only entries with at least 1 match\n  .sort((a, b) => b._score - a._score)  // sort descending by score\n  .slice(0, 3);                          // take top 3 entries\n\n// Build the context string to inject into the LLM prompt\nlet contextBlock = '';\nlet sources      = [];\n\nif (scored.length > 0) {\n  scored.forEach((e, idx) => {\n    contextBlock += `[${idx+1}] ${e.Content} (Source: ${e.Source})\\n\\n`;\n    sources.push(`${e.EntryID} — ${e.Topic} (${e.Source})`);\n  });\n}\n\nreturn {\n  json: {\n    question,\n    studentName,\n    contextFound: scored.length > 0,\n    contextBlock,\n    sources,\n    retrievedCount: scored.length,\n  }\n};\n"
      },

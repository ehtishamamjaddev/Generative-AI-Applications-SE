    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body;\nconst question = (body.question || '').trim();\nconst studentName = (body.studentName || 'Anonymous').trim();\nconst history = Array.isArray(body.history) ? body.history : [];\n\nif (!question) throw new Error('Missing required field: question');\n\nconst stopWords = new Set([\n  'what','is','are','the','a','an','of','in','to','and','or',\n  'how','does','do','can','why','when','where','which','who',\n  'me','my','explain','describe','tell','about','difference',\n  'between','give','example','examples','please','define'\n]);\n\nconst queryKeywords = question\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s]/g, '')\n  .split(/\\s+/)\n  .filter(w => w.length > 2 && !stopWords.has(w));\n\n// Extract keywords from last history question too\nconst historyKeywords = history.length > 0\n  ? (history[history.length-1].question || '')\n      .toLowerCase().replace(/[^a-z0-9\\s]/g,'').split(/\\s+/)\n      .filter(w => w.length > 2 && !stopWords.has(w))\n  : [];\n\n// Merge both for broader retrieval\nconst allKeywords = [...new Set([...queryKeywords, ...historyKeywords])];\n\nreturn {\n  json: {\n    question,\n    studentName,\n    history,\n    queryKeywords: allKeywords,\n    queryKeywordsStr: allKeywords.join(', '),\n  }\n};"
      },

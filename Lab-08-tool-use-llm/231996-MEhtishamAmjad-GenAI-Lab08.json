    {
      "parameters": {
        "jsCode": "const toolResult = $input.first().json;\nconst llmResponse = $('Travel Assistant LLM').first().json;\nconst toolCall = llmResponse.choices[0].message.tool_calls[0];\nconst prevMessages = $('Build LLM Payload').first().json.messages;\nconst currentCount = $('Increment Counter').isExecuted \n  ? $('Increment Counter').first().json.turn_count \n  : 0;\n\nreturn [{\n  json: {\n    messages: [\n      ...prevMessages,\n      {\n        role: 'assistant',\n        tool_calls: llmResponse.choices[0].message.tool_calls\n      },\n      {\n        role: 'tool',\n        tool_call_id: toolCall.id,\n        content: JSON.stringify(toolResult)\n      }\n    ],\n    turn_count: currentCount\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        -512
      ],
      "id": "61b30bed-7d39-4c78-8293-65746f6b607b",
      "name": "Inject Tool Result"
    },
    {
      "parameters": {
        "jsCode": "const isRevision = $('Inject Tool Result').isExecuted;\n\nconst tools = [\n  {\n    type: \"function\",\n    function: {\n      name: \"get_crop_price\",\n      description: \"Get current market price for a crop in a Pakistani city.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          crop: { type: \"string\" },\n          city: { type: \"string\" }\n        },\n        required: [\"crop\", \"city\"]\n      }\n    }\n  },\n  {\n    type: \"function\",\n    function: {\n      name: \"get_rainfall_forecast\",\n      description: \"Get rainfall forecast for a Pakistani region.\",\n      parameters: {\n        type: \"object\",\n        properties: {\n          region: { type: \"string\" }\n        },\n        required: [\"region\"]\n      }\n    }\n  }\n];\n\nconst messages = isRevision\n  ? $('Inject Tool Result').first().json.messages\n  : [\n      {\n        role: \"system\",\n        content: \"You are a Kisan assistant for Pakistani farmers. You have two tools: get_crop_price and get_rainfall_forecast. When a user asks about BOTH crop prices AND rainfall in the same question, you MUST call both tools. Call the first tool, receive the result, then call the second tool, receive that result, and ONLY THEN provide a final text summary combining both results. Do not give a final answer until you have called all relevant tools.\"\n      },\n      {\n        role: \"user\",\n        content: $('Webhook - Query Input').first().json.body.query\n      }\n    ];\n\nreturn [{\n  json: {\n    model: \"llama-3.1-8b-instant\",\n    temperature: 0.2,\n    max_tokens: 1024,\n    messages: messages,\n    tools: tools,\n    tool_choice: \"auto\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        -304
      ],
      "id": "5870ca14-b833-4717-b930-ab8e791cac6c",
      "name": "Build LLM Payload"
    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\nconst currentCount = Number(inputData.turn_count) || 0;\n\nreturn [{\n  json: {\n    messages: inputData.messages,\n    turn_count: currentCount + 1\n  }\n}];"
      },

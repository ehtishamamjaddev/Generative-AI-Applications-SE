    {
      "parameters": {
        "jsCode": "const llmResponse = $('Travel Assistant LLM').first().json;\nconst toolCall = llmResponse.choices[0].message.tool_calls[0];\nconst args = JSON.parse(toolCall.function.arguments);\n\nconst crop = args.crop?.toLowerCase();\nconst city = args.city?.toLowerCase();\n\nconst prices = {\n  \"wheat\":     { \"lahore\": 3200, \"karachi\": 3300, \"peshawar\": 3100, \"multan\": 3150 },\n  \"rice\":      { \"lahore\": 8500, \"karachi\": 8800, \"peshawar\": 8300, \"multan\": 8400 },\n  \"cotton\":    { \"lahore\": 9200, \"karachi\": 9500, \"peshawar\": 8900, \"multan\": 9100 },\n  \"sugarcane\": { \"lahore\": 280,  \"karachi\": 290,  \"peshawar\": 270,  \"multan\": 285  }\n};\n\nconst price = prices[crop]?.[city];\n\nreturn [{\n  json: {\n    crop: crop,\n    city: city,\n    price_per_kg: price ? `PKR ${price}` : 'Price not found',\n    tool_name: \"get_crop_price\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        -512
      ],
      "id": "9ed5505f-cb03-4fa7-b040-1cca9cde2fec",
      "name": "Crop Price Tool"
    },
    {
      "parameters": {
        "jsCode": "const llmResponse = $('Travel Assistant LLM').first().json;\nconst toolCall = llmResponse.choices[0].message.tool_calls[0];\nconst args = JSON.parse(toolCall.function.arguments);\nconst region = args.region?.toLowerCase();\n\nconst rainfall = {\n  \"punjab\":      { forecast: \"45mm\", days: 5,  status: \"Expected rain mid-week\" },\n  \"sindh\":       { forecast: \"15mm\", days: 7,  status: \"Light rain expected\" },\n  \"kpk\":         { forecast: \"65mm\", days: 3,  status: \"Heavy rain warning\" },\n  \"balochistan\": { forecast: \"5mm\",  days: 10, status: \"Dry conditions continue\" }\n};\n\nconst data = rainfall[region];\n\nreturn [{\n  json: {\n    region: region,\n    forecast: data?.forecast ?? 'Not found',\n    days_ahead: data?.days ?? 0,\n    status: data?.status ?? 'No data',\n    tool_name: \"get_rainfall_forecast\"\n  }\n}];"
      },

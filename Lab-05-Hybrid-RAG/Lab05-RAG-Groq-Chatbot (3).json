    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body;\nconst question = (body.question || '').trim();\nconst studentName = (body.studentName || 'Anonymous').trim();\nconst history = Array.isArray(body.history) ? body.history : [];\nif (!question) throw new Error('Missing required field: question');\nconst windowedHistory = history.slice(-10);\nreturn { json: { question, studentName, history: windowedHistory } };"
      },

      "id": "d346f61a-7767-450b-836c-e7a90330af1e",
      "name": "Pinecone Query",
      "credentials": {
        "httpHeaderAuth": {
          "id": "6ZH91HAaB4Vouu0U",
          "name": "Pinecone"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const pineconeResult = $input.item.json;\nconst matches = pineconeResult.matches || [];\nconst THRESHOLD = 0.60;\nconst relevant = matches.filter(m => m.score >= THRESHOLD);\nlet contextBlock = '';\nconst sources = [];\nconst scores = [];\nif (relevant.length > 0) {\n  relevant.forEach((m, idx) => {\n    const meta = m.metadata || {};\n    contextBlock += '[' + (idx+1) + '] ' + meta.content + ' (Source: ' + meta.source + ')\\n\\n';\n    sources.push(meta.entryId + ' - ' + meta.topic + ' (' + meta.source + ')');\n    scores.push(parseFloat(m.score.toFixed(3)));\n  });\n}\n\nconst question = $input.item.json.question || '';\nconst studentName = $input.item.json.studentName || '';\nconst history = $input.item.json.history || [];\n\nreturn {\n  contextFound: relevant.length > 0,\n  contextBlock,\n  sources,\n  scores,\n  topScore: scores.length > 0 ? Math.max(...scores) : 0,\n  retrievedCount: relevant.length,\n  question,\n  studentName,\n  history\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

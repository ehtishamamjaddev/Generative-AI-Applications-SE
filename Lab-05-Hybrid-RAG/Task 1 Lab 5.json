        "jsCode": "const body = $input.item.json.body;\nconst question = (body.question || '').trim();\nconst studentName = (body.studentName || 'Anonymous').trim();\nconst history = Array.isArray(body.history) ? body.history : [];\nconst minScore = typeof body.minScore === 'number' ? body.minScore : 0.60;\n\nif (!question) throw new Error('Missing required field: question');\n\nconst windowedHistory = history.slice(-10);\nreturn { json: { question, studentName, history: windowedHistory, minScore } };"

    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const pineconeResult = $input.item.json;\nconst matches = pineconeResult.matches || [];\n\nconst THRESHOLD = $input.item.json.minScore ?? 0.60;\nconst relevant = matches.filter(m => m.score >= THRESHOLD);\n\nlet contextBlock = '';\nconst sources = [];\nconst scores = [];\nconst scoreLabels = [];\n\nif (relevant.length > 0) {\n  relevant.forEach((m, idx) => {\n    const meta = m.metadata || {};\n    contextBlock += '[' + (idx+1) + '] ' + meta.content + ' (Source: ' + meta.source + ')\\n\\n';\n    sources.push(meta.entryId + ' - ' + meta.topic + ' (' + meta.source + ')');\n    scores.push(parseFloat(m.score.toFixed(3)));\n    scoreLabels.push((meta.entryId || 'Unknown') + ': ' + m.score.toFixed(3));\n  });\n}\n\nconst question = $input.item.json.question || '';\nconst studentName = $input.item.json.studentName || '';\nconst history = $input.item.json.history || [];\nconst minScore = $input.item.json.minScore ?? 0.60;\n\nreturn {\n  contextFound: relevant.length > 0,\n  contextBlock,\n  sources,\n  scores,\n  scoreLabels,\n  topScore: scores.length > 0 ? Math.max(...scores) : 0,\n  retrievedCount: relevant.length,\n  question,\n  studentName,\n  history,\n  minScore\n};"
      },
